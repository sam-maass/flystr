{
  "parser": "babel-eslint",
  "extends": ["eslint:recommended", "plugin:react/recommended"],
  "plugins": ["react", "jest"],
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true,
      "experimentalObjectRestSpread": true
    }
  },
  "env": {
    "browser": true,
    "node": true,
    "es6": true,
    "jest/globals": true
  },
  "rules": {
    "semi": 2,
    "jsx-a11y/anchor-is-valid": "off",
    "react/display-name": "off",
    "react/prefer-stateless-function": 1,
    "react/no-unescaped-entities": 0,
    "eqeqeq": 2,
    "no-implicit-coercion": 2,
    "no-multi-spaces": 2,
    "no-useless-return": 2,
    "no-useless-computed-key": 2,
    "no-useless-rename": 2,
    "no-var": 2,
    "object-shorthand": 2,
    "prefer-arrow-callback": 2,
    "prefer-const": 2,
    "sort-vars": 2,
    "prefer-spread": 2,
    "prefer-template": 2,
    "prefer-destructuring": ["warn", { "array": false }],
    "no-unused-vars": [
      "error",
      { "ignoreRestSiblings": true, "varsIgnorePattern": "[iI]gnored" }
    ]
  }
}
