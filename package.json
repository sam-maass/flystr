{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "jest": {
    "verbose": true,
    "testURL": "http://localhost/",
    "setupTestFrameworkScriptFile": "./jestSetup.js",
    "moduleNameMapper": {
      ".*\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/mocks/image.js"
    }
  },
  "bundlesize": [
    {
      "path": "./build/static/js/main*.js",
      "maxSize": "500 kB"
    }
  ],
  "dependencies": {
    "@material-ui/core": "^3.1.0",
    "@material-ui/icons": "^3.0.1",
    "autosuggest-highlight": "^3.1.1",
    "axios": "0.18.0",
    "emotion": "^9.2.9",
    "emotion-server": "^9.2.9",
    "express": "^4.16.3",
    "formik": "^1.3.0",
    "helmet": "^3.13.0",
    "jsonwebtoken": "^8.3.0",
    "moment": "^2.22.2",
    "ms": "^2.1.1",
    "prop-types": "^15.6.2",
    "qs": "^6.5.2",
    "react": "^16.5.1",
    "react-autosuggest": "^9.4.1",
    "react-dom": "^16.5.1",
    "react-emotion": "^9.2.9",
    "react-google-login": "3.2.1",
    "react-helmet": "^5.2.0",
    "react-jss": "^8.6.1",
    "react-loadable": "^5.5.0",
    "react-redux": "^5.0.7",
    "react-router": "^4.3.1",
    "react-router-dom": "^4.3.1",
    "react-scripts": "^1.1.5",
    "redux": "^4.0.0",
    "redux-logger": "^3.0.6",
    "redux-promise-middleware": "^5.1.1",
    "redux-thunk": "^2.3.0",
    "route-parser": "0.0.5",
    "string-hash": "^1.1.3",
    "yup": "^0.26.5"
  },
  "scripts": {
    "format": "prettier --write 'src/**/*.js'",
    "start": "PORT=3001 react-scripts start",
    "start-server": "NODE_ENV=production node server/bootstrap.js",
    "build": "react-scripts build",
    "lint": "eslint --fix 'src/**/*.js'",
    "test-watch": "jest -o",
    "test-update": "jest -u",
    "runTests": "jest",
    "test": "npm run lint && jest && npm run build && bundlesize",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public",
    "upgrade-interactive": "npm-check --update"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run lint && npm run format && git add .",
      "pre-commit": "npm run format"
    }
  },
  "devDependencies": {
    "@storybook/addon-actions": "^3.4.10",
    "@storybook/addon-links": "^3.4.10",
    "@storybook/addons": "^3.4.10",
    "@storybook/react": "^3.4.10",
    "babel-core": "^6.26.3",
    "babel-plugin-syntax-dynamic-import": "^6.18.0",
    "babel-plugin-transform-class-properties": "6.24.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-react-app": "^3.1.2",
    "babel-runtime": "^6.26.0",
    "bundlesize": "^0.17.0",
    "enzyme": "^3.6.0",
    "enzyme-adapter-react-16": "^1.5.0",
    "eslint": "^5.6.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-jest": "^21.22.0",
    "eslint-plugin-react": "^7.11.1",
    "husky": "^1.0.0-rc.13",
    "ignore-styles": "^5.0.1",
    "jest-cli": "^23.6.0",
    "jest-emotion": "9.2.7",
    "lint-staged": "^7.2.2",
    "npm-check": "^5.8.0",
    "prettier": "^1.14.2",
    "react-test-renderer": "^16.5.1",
    "redux-devtools-extension": "^2.13.5",
    "webpack-bundle-analyzer": "^3.0.2"
  }
}
