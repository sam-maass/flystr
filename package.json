{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "bundlesize": [
    {
      "path": "./build/static/js/main*.js",
      "maxSize": "250 kB"
    }
  ],
  "dependencies": {
    "autosuggest-highlight": "^3.1.1",
    "axios": "0.18.0",
    "formik": "^0.11.11",
    "material-ui": "^1.0.0-beta.42",
    "material-ui-icons": "^1.0.0-beta.36",
    "moment": "^2.22.1",
    "prop-types": "^15.6.1",
    "qs": "^6.5.1",
    "react": "16.3.2",
    "react-autosuggest": "^9.3.4",
    "react-dom": "16.3.2",
    "react-google-login": "3.2.1",
    "react-redux": "^5.0.7",
    "react-router": "^4.2.0",
    "react-router-dom": "^4.2.2",
    "react-scripts": "1.1.4",
    "redux": "^4.0.0",
    "redux-logger": "^3.0.6",
    "redux-promise-middleware": "^5.1.1",
    "redux-thunk": "^2.2.0",
    "string-hash": "^1.1.3",
    "yup": "^0.24.1"
  },
  "scripts": {
    "format": "prettier --write 'src/**/*.js'",
    "precommit": "lint-staged",
    "start": "PORT=3001 react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint --fix 'src/**/*.js'",
    "test": "npm run lint && npm run build && bundlesize",
    "eject": "react-scripts eject"
  },
  "lint-staged": {
    "src/**/*.{js,json,css,md}": [
      "prettier --write",
      "git add"
    ],
    "src/**/*.{js,json}": [
      "eslint --fix",
      "git add"
    ]
  },
  "devDependencies": {
    "bundlesize": "^0.17.0",
    "eslint": "^4.19.1",
    "eslint-config-airbnb": "^16.1.0",
    "eslint-plugin-react": "^7.7.0",
    "husky": "^0.14.3",
    "jest-cli": "^22.4.3",
    "lint-staged": "^7.0.4",
    "prettier": "^1.12.1",
    "redux-devtools-extension": "^2.13.2",
    "webpack-bundle-analyzer": "^2.11.1"
  }
}
