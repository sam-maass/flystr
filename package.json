{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "jest": {
    "verbose": true,
    "testURL": "http://localhost/",
    "setupTestFrameworkScriptFile": "./jestSetup.js",
    "moduleNameMapper": {
      ".*\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/mocks/image.js"
    }
  },
  "bundlesize": [
    {
      "path": "./build/static/js/main*.js",
      "maxSize": "500 kB"
    }
  ],
  "dependencies": {
    "@material-ui/core": "^1.4.1",
    "@material-ui/icons": "^2.0.0",
    "autosuggest-highlight": "^3.1.1",
    "axios": "0.18.0",
    "emotion": "^9.2.6",
    "formik": "^1.0.2",
    "jsonwebtoken": "^8.3.0",
    "moment": "^2.22.2",
    "ms": "^2.1.1",
    "prop-types": "^15.6.2",
    "qs": "^6.5.2",
    "react": "16.4.1",
    "react-autosuggest": "^9.3.4",
    "react-dom": "16.4.1",
    "react-emotion": "9.2.6",
    "react-google-login": "3.2.1",
    "react-redux": "^5.0.7",
    "react-router": "^4.3.1",
    "react-router-dom": "^4.3.1",
    "react-scripts": "1.1.4",
    "redux": "^4.0.0",
    "redux-logger": "^3.0.6",
    "redux-promise-middleware": "^5.1.1",
    "redux-thunk": "^2.3.0",
    "string-hash": "^1.1.3",
    "yup": "^0.26.0"
  },
  "scripts": {
    "format": "prettier --write 'src/**/*.js'",
    "start": "PORT=3001 react-scripts start",
    "build": "react-scripts build",
    "lint": "eslint --fix 'src/**/*.js'",
    "test-watch": "jest -o",
    "test-update": "jest -u",
    "runTests": "jest",
    "test": "npm run lint && jest && npm run build && bundlesize",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run lint && npm run format && git add .",
      "pre-commit": "npm run lint && npm run format && jest && git add ."
    }
  },
  "devDependencies": {
    "@storybook/addon-actions": "^3.4.8",
    "@storybook/addon-links": "^3.4.8",
    "@storybook/addons": "^3.4.8",
    "@storybook/react": "^3.4.8",
    "babel-core": "^6.26.3",
    "babel-plugin-syntax-dynamic-import": "^6.18.0",
    "babel-plugin-transform-class-properties": "6.24.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-runtime": "^6.26.0",
    "bundlesize": "^0.17.0",
    "enzyme": "3.3.0",
    "enzyme-adapter-react-16": "1.1.1",
    "eslint": "^5.2.0",
    "eslint-config-airbnb": "^17.0.0",
    "eslint-plugin-jest": "^21.18.0",
    "eslint-plugin-react": "^7.10.0",
    "husky": "^1.0.0-rc.13",
    "jest-cli": "^23.4.2",
    "jest-emotion": "9.2.6",
    "lint-staged": "^7.2.0",
    "prettier": "^1.13.7",
    "react-test-renderer": "^16.4.1",
    "redux-devtools-extension": "^2.13.5",
    "webpack-bundle-analyzer": "^2.13.1"
  }
}
