{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "jest": {
    "verbose": true,
    "testURL": "http://localhost/",
    "setupTestFrameworkScriptFile": "./jestSetup.js",
    "moduleNameMapper": {
      ".*\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/mocks/image.js"
    }
  },
  "bundlesize": [
    {
      "path": "./build/static/js/main*.js",
      "maxSize": "500 kB"
    }
  ],
  "dependencies": {
    "@material-ui/core": "^3.1.2",
    "@material-ui/icons": "^3.0.1",
    "autosuggest-highlight": "^3.1.1",
    "axios": "0.18.0",
    "emotion": "^9.2.12",
    "emotion-server": "^9.2.12",
    "express": "^4.16.3",
    "formik": "^1.3.1",
    "helmet": "^3.13.0",
    "jsonwebtoken": "^8.3.0",
    "moment": "^2.22.2",
    "ms": "^2.1.1",
    "prop-types": "^15.6.2",
    "qs": "^6.5.2",
    "react": "^16.5.2",
    "react-autosuggest": "^9.4.2",
    "react-dom": "^16.5.2",
    "react-emotion": "^9.2.12",
    "react-google-login": "3.2.1",
    "react-helmet": "^5.2.0",
    "react-jss": "^8.6.1",
    "react-loadable": "^5.5.0",
    "react-redux": "^5.0.7",
    "react-router": "^4.3.1",
    "react-router-dom": "^4.3.1",
    "react-scripts": "^2.0.4",
    "redux": "^4.0.0",
    "redux-logger": "^3.0.6",
    "redux-promise-middleware": "^5.1.1",
    "redux-thunk": "^2.3.0",
    "route-parser": "0.0.5",
    "string-hash": "^1.1.3",
    "yup": "^0.26.6"
  },
  "scripts": {
    "format": "prettier --write 'src/**/*.js'",
    "start": "PORT=3001 react-scripts start",
    "start-server": "NODE_ENV=production node server/bootstrap.js",
    "start-dev-server": "NODE_ENV=development node server/bootstrap.js",
    "build": "react-scripts build",
    "lint": "eslint --fix 'src/**/*.js'",
    "test-watch": "jest -o",
    "test-update": "jest -u",
    "runTests": "jest",
    "test": "npm run lint && jest && npm run build && bundlesize",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public",
    "upgrade-interactive": "npm-check --update"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run lint && npm run format && git add .",
      "pre-commit": "npm run format"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.1.2",
    "@babel/plugin-proposal-class-properties": "^7.1.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.0.0",
    "@babel/preset-env": "^7.1.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/register": "^7.0.0",
    "@babel/runtime": "^7.1.2",
    "@storybook/addon-actions": "^3.4.11",
    "@storybook/addon-links": "^3.4.11",
    "@storybook/addons": "^3.4.11",
    "@storybook/react": "^3.4.11",
    "babel-plugin-dynamic-import-node": "^2.1.0",
    "bundlesize": "^0.17.0",
    "enzyme": "^3.7.0",
    "enzyme-adapter-react-16": "^1.6.0",
    "eslint": "5.6.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-plugin-jest": "^21.24.1",
    "eslint-plugin-react": "^7.11.1",
    "husky": "^1.1.1",
    "ignore-styles": "^5.0.1",
    "jest-cli": "^23.6.0",
    "jest-emotion": "^9.2.11",
    "lint-staged": "^7.3.0",
    "npm-check": "^5.9.0",
    "prettier": "^1.14.3",
    "react-test-renderer": "^16.5.2",
    "redux-devtools-extension": "^2.13.5",
    "webpack-bundle-analyzer": "^3.0.2"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
