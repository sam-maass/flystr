// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`ImageHeader: default 1`] = `
.emotion-1 {
  width: 100%;
}

.emotion-0 {
  color: #263238;
  font-family: 'Comfortaa';
  font-size: 24px;
  font-style: normal;
  font-weight: bold;
  -webkit-letter-spacing: 0.1em;
  -moz-letter-spacing: 0.1em;
  -ms-letter-spacing: 0.1em;
  letter-spacing: 0.1em;
  line-height: 1.7em;
  margin-bottom: 8px;
  text-transform: uppercase;
  text-align: center;
  text-shadow: 0px 4px 4px rgba(0,0,0,0.25);
  color: #FAFAFA;
}

@media only screen and (min-width:1024px) {
  .emotion-0 {
    font-size: 36px;
  }
}

.emotion-2 {
  background-image: url(https://flystr.com/destination-images/header/airplane1.jpg);
  background-size: cover;
  background-repeat: no-repeat;
  background-position-y: 50%;
  padding: 10px;
  display: grid;
  width: 100%;
  box-shadow: 0px 1px 3px 0px rgba(0,0,0,0.2), 0px 1px 1px 0px rgba(0,0,0,0.14),0px 2px 1px -1px rgba(0,0,0,0.12);
  grid-template-rows: 100px 1fr 100px;
  grid-template-areas: 'logo' 'headline' 'button';
}

@media only screen and (min-width:1024px) {
  .emotion-2 {
    background-image: url(https://flystr.com/destination-images/header-wide/airplane1.jpg);
    grid-template-columns: 150px 1fr 150px;
    grid-template-areas: 'logo . .' '. headline .' '. button .';
  }
}

.emotion-2 .headline {
  grid-area: headline;
  justify-self: center;
  -webkit-align-self: center;
  -ms-flex-item-align: center;
  align-self: center;
}

.emotion-2 .logo {
  grid-area: logo;
  width: 150px;
  height: 50px;
  margin: auto;
  background-image: url('/logo.svg');
  background-size: contain;
  background-repeat: no-repeat;
  margin-bottom: 20px;
}

@media only screen and (min-width:1024px) {
  .emotion-2 .logo {
    margin: 0;
    width: 300px;
  }
}

.emotion-2 .buttonbox {
  grid-area: button;
  -webkit-align-self: center;
  -ms-flex-item-align: center;
  align-self: center;
  justify-self: center;
  padding: 32px;
}

.emotion-2 .buttonbox a {
  -webkit-text-decoration: none;
  text-decoration: none;
}

.emotion-2 .button {
  border: 2px solid #FF6D00;
  border-radius: 4px;
  background-color: rgba(255,255,255,0.1);
  padding: 8px 16px;
  box-shadow: 0px 1px 5px 0px rgba(0,0,0,0.2), 0px 2px 2px 0px rgba(0,0,0,0.14),0px 3px 1px -2px rgba(0,0,0,0.12);
  color: #263238;
  font-family: 'Comfortaa';
  font-size: 18px;
  font-style: normal;
  font-weight: bold;
  -webkit-letter-spacing: 0.1em;
  -moz-letter-spacing: 0.1em;
  -ms-letter-spacing: 0.1em;
  letter-spacing: 0.1em;
  margin-bottom: 8px;
  line-height: normal;
  color: #FAFAFA;
  font-weight: bold;
}

.emotion-2 .button:hover {
  background-color: rgba(255,255,255,0.2);
}

<div
  className="emotion-2"
>
  <div
    className="logo"
  />
  <div
    className="headline"
  >
    <div
      className="emotion-1"
    >
      <div
        className="emotion-0"
      >
        select your destination
        <br />
        we find the best flights
      </div>
    </div>
  </div>
  <div
    className="buttonbox"
  >
    <a
      href="/deals"
      onClick={[Function]}
    >
      <span
        className="button"
      >
        Find cheap flights
      </span>
    </a>
  </div>
</div>
`;
